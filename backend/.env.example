# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://fileflow:fileflow@localhost:5432/fileflow"

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRY_DAYS=7

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# ─── Microsoft / Azure OAuth (login + OneDrive) ───────────────────────────────
# Create an app at https://portal.azure.com/ → App registrations
# Required scopes (login): openid profile email User.Read
# Required scopes (OneDrive): Files.ReadWrite.All offline_access
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_CALLBACK_URL="http://localhost:3001/api/auth/microsoft/callback"

ONEDRIVE_CLIENT_ID=""
ONEDRIVE_CLIENT_SECRET=""
ONEDRIVE_CALLBACK_URL="http://localhost:3001/api/auth/onedrive/callback"

# ─── Dropbox ──────────────────────────────────────────────────────────────────
# Create an app at https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=""
DROPBOX_APP_SECRET=""
DROPBOX_CALLBACK_URL="http://localhost:3001/api/auth/dropbox/callback"

# ─── Apple OAuth ──────────────────────────────────────────────────────────────
# 1. Enable "Sign in with Apple" for an App ID in https://developer.apple.com/
# 2. Create a Services ID (this becomes APPLE_CLIENT_ID, e.g. com.example.fileflow.signin)
#    and register your redirect URI.
# 3. Create a Sign in with Apple key (.p8) — you download it only once.
# 4. APPLE_PRIVATE_KEY: paste the full PEM content, replacing newlines with \n
APPLE_CLIENT_ID="com.berzuk.fileflow.signin"
APPLE_TEAM_ID="JNS929H53C"
APPLE_KEY_ID="89YCDALZ3Q"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQgg9mPqomsGz8uBPzW\n0iS5/V1/vRZq783RyJ2Q9TctaD+gCgYIKoZIzj0DAQehRANCAATYojuPxzkrofAi\nHBOB9jROZ4TRr6XmT5TFnVVWT4M66HEbNLYvBZIXB2rgEg2LXKIoJJgFT+599MgW\nsMXlLJcl\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL="https://yourdomain.com/api/auth/apple/callback"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:5173"
